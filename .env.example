# ─── Production (Coolify) ───
# Set these as BUILD-TIME env / Docker build args, then redeploy frontend.

NEXT_PUBLIC_SITE_URL=https://printworks.lk
NEXT_PUBLIC_API_URL=https://api.printworks.lk
NEXT_PUBLIC_GRAPHQL_URL=https://api.printworks.lk/graphql

# Social profiles (header top bar)
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/yourpage
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/yourpage
NEXT_PUBLIC_SOCIAL_TIKTOK=https://www.tiktok.com/@yourpage
NEXT_PUBLIC_SOCIAL_PINTEREST=https://www.pinterest.com/yourpage

# Uploads are served from NEXT_PUBLIC_API_URL/storage/… (set APP_URL on backend to match)

# Optional: require login before submitting product reviews
# NEXT_PUBLIC_REVIEWS_REQUIRE_AUTH=1

# ─── Local development ───
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql
