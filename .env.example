# Public site URL (SEO, metadata) — your Next.js domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Laravel API — Coolify: backend sslip.io or https://api.printworks.lk
# Must be set at Docker BUILD time (see Dockerfile ARG) then redeploy.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Social profiles (header top bar)
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/yourpage
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/yourpage
NEXT_PUBLIC_SOCIAL_TIKTOK=https://www.tiktok.com/@yourpage
NEXT_PUBLIC_SOCIAL_PINTEREST=https://www.pinterest.com/yourpage

# Optional: GraphQL endpoint (Lighthouse)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql
